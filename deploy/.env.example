# Shared platform domain for Traefik path-based routing.
# Psina handles /auth.v1.* and /.well-known/* under this domain.
# Must match EYE_DOMAIN in greedy-eye — all services share one domain.
# For local development: eye.localhost
# For self-hosting: eye.yourdomain.com
PSINA_DOMAIN=eye.localhost
PSINA_COOKIE_DOMAIN=.localhost
