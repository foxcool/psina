---
# Generated by Ansible — do not edit manually
# Role: psina  |  Domain: {{ psina_platform_domain }}

volumes:
  postgres_data:

services:
  psina:
    image: "{{ psina_image }}"
    restart: unless-stopped
    environment:
      PSINA_DB_URL: "postgres://{{ psina_db_user }}:{{ psina_db_password }}@postgres:5432/{{ psina_db_name }}?sslmode=disable"
      PSINA_SERVER_PORT: "{{ psina_http_port }}"
      PSINA_LOGGER_LEVEL: "{{ psina_log_level | lower }}"
      PSINA_COOKIE_ENABLED: "{{ psina_cookie_enabled | lower }}"
      PSINA_COOKIE_DOMAIN: "{{ psina_cookie_domain }}"
      PSINA_COOKIE_SECURE: "{{ psina_cookie_secure | lower }}"
      PSINA_COOKIE_SAMESITE: "{{ psina_cookie_samesite }}"
{% if psina_jwt_private_key %}
      PSINA_JWT_PRIVATEKEYPATH: "/run/secrets/jwt_private_key"
    volumes:
      - "{{ psina_app_dir }}/secrets/jwt_private_key:/run/secrets/jwt_private_key:ro"
{% endif %}
    depends_on:
      postgres:
        condition: service_healthy
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=proxy"
      - "traefik.http.routers.psina.rule=Host(`{{ psina_platform_domain }}`) && (PathPrefix(`/auth.v1.`) || PathPrefix(`/.well-known`))"
      - "traefik.http.routers.psina.entrypoints=websecure"
      - "traefik.http.routers.psina.tls=true"
      - "traefik.http.routers.psina.priority=30"
      - "traefik.http.services.psina.loadbalancer.server.port={{ psina_http_port }}"
      - "traefik.http.services.psina.loadbalancer.server.scheme=h2c"
{% if psina_traefik_middlewares %}
      - "traefik.http.routers.psina.middlewares={{ psina_traefik_middlewares }}"
{% endif %}
    networks:
      - proxy
      - default

  postgres:
    image: postgres:17-alpine
    restart: unless-stopped
    environment:
      POSTGRES_USER: "{{ psina_db_user }}"
      POSTGRES_PASSWORD: "{{ psina_db_password }}"
      POSTGRES_DB: "{{ psina_db_name }}"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ psina_db_user }} -d {{ psina_db_name }}"]
      interval: 5s
      timeout: 5s
      retries: 5

networks:
  proxy:
    external: true
