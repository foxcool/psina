# Database Configuration
PSINA_DB_URL=postgres://psina:password@postgres:5432/psina?sslmode=disable

# Server Configuration
PSINA_PORT=8080
PSINA_HOST=0.0.0.0

# Logging
PSINA_LOG_LEVEL=INFO

# JWT Configuration
# Generate RSA key pair:
# openssl genrsa -out jwt.key 2048
# openssl rsa -in jwt.key -pubout -out jwt.pub
PSINA_JWT_PRIVATE_KEY_FILE=/secrets/jwt.key
PSINA_JWT_PUBLIC_KEY_FILE=/secrets/jwt.pub
PSINA_JWT_ISSUER=psina
PSINA_JWT_ACCESS_TOKEN_TTL=15m
PSINA_JWT_REFRESH_TOKEN_TTL=168h

# Optional: Sentry for error tracking
# PSINA_SENTRY_DSN=
# PSINA_SENTRY_ENVIRONMENT=development

# Optional: Metrics
# PSINA_METRICS_ENABLED=true
# PSINA_METRICS_PORT=9090
